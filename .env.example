# Voice IDE local settings
# OAuth sign-in is managed outside this file.

BUILD_MODE=hybrid
OPENAI_MODEL=gpt-5.4
ANTHROPIC_MODEL=claude-sonnet-4-0
OPENROUTER_MODEL=openai/gpt-5.4
# OpenAI BYOK.
# OPENAI_API_KEY=
# Anthropic BYOK
# ANTHROPIC_API_KEY=
# OpenRouter BYOK
# OPENROUTER_API_KEY=

# Reasoning effort passed to the provider (none|low|medium|high|xhigh)
# VOICEIDE_REASONING=xhigh

# LLM_PROVIDER=openai
# DEFAULT_WORKSPACE=/absolute/path/to/workspaces-root
# Used as the suggested project root,
# and as the base root for provisioned user workspaces.
