# Appora Environment Configuration

# Provisioned workspace root (default: ~/.voiceide-home)
# The API provisions user workspaces under: <root>/users/<user-id>
# You can use any absolute path or ~ for home directory
DEFAULT_WORKSPACE=~/.voiceide-home

# Server configuration
HOST=0.0.0.0
PORT=8787

# User login OAuth (optional - for Google authentication)
# Leave empty if you don't want Google sign-in
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# LLM routing
# Appora only talks to 9Router. 9Router expands free/premium providers,
# combos, quota checks, and fallback behind its OpenAI-compatible /v1 API.
LLM_PROVIDER=nine_router
NINE_ROUTER_BASE_URL=http://127.0.0.1:20128/v1
NINE_ROUTER_API_KEY=
NINE_ROUTER_MODEL=free-forever

# Appora-managed free router for hosted users.
# Fill these in production so users can code with free-forever without BYOK.
# Premium/custom 9Router routes still use the user's own 9Router endpoint/key.
APPORA_MANAGED_9ROUTER_BASE_URL=https://router.appora.ai/v1
APPORA_MANAGED_9ROUTER_API_KEY=
APPORA_MANAGED_FREE_MODEL=free-forever
APPORA_FREE_DAILY_MESSAGES=30

BUILD_MODE=hybrid
FRIENDLY_FREE_TIER_MODE=true
AGENT_REFINEMENT_MODE=auto
AGENT_MIN_GAP_SECONDS=4.0
AGENT_REQUESTS_PER_MINUTE=8
NINE_ROUTER_REQUESTS_PER_MINUTE=

# Supabase (optional, but required for hosted persistence + shared RAG)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Agent configuration (optional)
AGENT_ENDPOINT=

# Preview server configuration
PREVIEW_PORT=8080
