# Voice IDE Environment Configuration

# Provisioned workspace root (default: ~/.voiceide-home)
# The API provisions user workspaces under: <root>/users/<user-id>
# You can use any absolute path or ~ for home directory
DEFAULT_WORKSPACE=~/.voiceide-home

# Server configuration
HOST=0.0.0.0
PORT=8787

# User login OAuth (optional - for Google authentication)
# Leave empty if you don't want Google sign-in
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# LLM provider setup (BYOK only)
# OpenRouter is the hosted default because it supports free/cheap model routing.
LLM_PROVIDER=openrouter
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENROUTER_API_KEY=
OPENROUTER_MODEL=x-ai/grok-4.3
GROQ_API_KEY=
GROQ_MODEL=groq/compound
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro-preview
TOGETHER_API_KEY=
TOGETHER_MODEL=deepseek-ai/DeepSeek-V4-Pro
CEREBRAS_API_KEY=
CEREBRAS_MODEL=zai-glm-4.7
XAI_API_KEY=
XAI_MODEL=grok-4.3
BUILD_MODE=hybrid
FRIENDLY_FREE_TIER_MODE=true
AGENT_REFINEMENT_MODE=auto
AGENT_MIN_GAP_SECONDS=4.0
AGENT_REQUESTS_PER_MINUTE=8
OPENAI_REQUESTS_PER_MINUTE=
ANTHROPIC_REQUESTS_PER_MINUTE=
OPENROUTER_REQUESTS_PER_MINUTE=
GROQ_REQUESTS_PER_MINUTE=
GEMINI_REQUESTS_PER_MINUTE=
TOGETHER_REQUESTS_PER_MINUTE=
CEREBRAS_REQUESTS_PER_MINUTE=
XAI_REQUESTS_PER_MINUTE=

# Supabase (optional, but required for hosted persistence + shared RAG)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Agent configuration (optional)
AGENT_ENDPOINT=

# Preview server configuration
PREVIEW_PORT=8080
