# Voice IDE Environment Configuration

# Provisioned workspace root (default: ~/.voiceide-home)
# The API provisions user workspaces under: <root>/users/<user-id>
# You can use any absolute path or ~ for home directory
DEFAULT_WORKSPACE=~/.voiceide-home

# Server configuration
HOST=0.0.0.0
PORT=8787

# User login OAuth (optional - for Google authentication)
# Leave empty if you don't want Google sign-in
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# LLM provider setup (BYOK only)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-0
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.4
BUILD_MODE=hybrid
FRIENDLY_FREE_TIER_MODE=true
AGENT_REFINEMENT_MODE=auto
AGENT_MIN_GAP_SECONDS=4.0
AGENT_REQUESTS_PER_MINUTE=8
OPENAI_REQUESTS_PER_MINUTE=
ANTHROPIC_REQUESTS_PER_MINUTE=
OPENROUTER_REQUESTS_PER_MINUTE=

# Agent configuration (optional)
AGENT_ENDPOINT=

# Preview server configuration
PREVIEW_PORT=8080
